# ─── Google OAuth2 ───────────────────────────────────────────
# Obtenlos desde Google Cloud Console (ver README)
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx
# Este lo genera setup.js automáticamente
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxx

# ─── Drive ───────────────────────────────────────────────────
# Opcional: puedes dejarlo vacío y cambiarlo desde la interfaz web
DRIVE_FOLDER_ID=

# ─── WhatsApp ────────────────────────────────────────────────
# Nombre EXACTO del grupo (deja vacío para escuchar todos los grupos)
WA_GROUP_NAME=Mi Grupo

# ─── Servidor ────────────────────────────────────────────────
PORT=3000
